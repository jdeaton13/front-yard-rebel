---
interface Props {
  name: string;
  scientificName: string;
  description: string;
  benefits: string[];
  imageAlt?: string;
}

const { name, scientificName, description, benefits, imageAlt = name } = Astro.props;
---

<div class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow border border-moss-100">
  <!-- Placeholder Image -->
  <div class="h-48 bg-gradient-to-br from-moss-200 to-moss-300 flex items-center justify-center">
    <div class="text-center">
      <span class="text-6xl">🌿</span>
      <p class="text-moss-600 text-sm mt-2">Image: {imageAlt}</p>
    </div>
  </div>
  
  <div class="p-6">
    <h3 class="text-xl font-bold text-moss-800 mb-1">{name}</h3>
    <p class="text-moss-500 text-sm italic mb-3">{scientificName}</p>
    <p class="text-moss-600 mb-4">{description}</p>
    
    <div class="flex flex-wrap gap-2">
      {benefits.map((benefit) => (
        <span class="bg-moss-100 text-moss-700 text-xs px-3 py-1 rounded-full">
          {benefit}
        </span>
      ))}
    </div>
  </div>
</div>
