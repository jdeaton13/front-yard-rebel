---
interface Props {
  title?: string;
  subtitle?: string;
  showCTA?: boolean;
}

const { 
  title = "From Grass to Garden",
  subtitle = "Transform your Jacksonville front yard into a beautiful, sustainable Florida native plant garden. Better for you, better for wildlife, better for Florida.",
  showCTA = true
} = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 bg-gradient-to-br from-moss-100 via-moss-50 to-earth-100"></div>
  
  <!-- Decorative Elements -->
  <div class="absolute top-20 left-10 w-32 h-32 bg-moss-200 rounded-full opacity-50 blur-3xl"></div>
  <div class="absolute bottom-20 right-10 w-48 h-48 bg-earth-200 rounded-full opacity-50 blur-3xl"></div>
  <div class="absolute top-1/2 left-1/4 w-24 h-24 bg-moss-300 rounded-full opacity-30 blur-2xl"></div>
  
  <!-- Leaf Pattern Overlay -->
  <div class="absolute inset-0 opacity-5">
    <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
      <pattern id="leaves" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
        <path d="M10 2 Q15 10 10 18 Q5 10 10 2" fill="currentColor" class="text-moss-600"/>
      </pattern>
      <rect width="100%" height="100%" fill="url(#leaves)"/>
    </svg>
  </div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <!-- Logo -->
    <div class="mb-8">
      <img 
        src="/logo.png" 
        alt="Front Yard Rebel - From Grass to Garden" 
        class="w-32 h-32 md:w-40 md:h-40 mx-auto rounded-full shadow-xl"
      />
    </div>
    
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-moss-100 border border-moss-200 rounded-full px-4 py-2 mb-8">
      <span class="text-moss-600 text-sm font-medium">🌿 Based in Jacksonville, FL</span>
    </div>
    
    <!-- Main Title -->
    <h1 class="text-5xl md:text-7xl font-bold text-moss-900 mb-6 leading-tight">
      {title}
    </h1>
    
    <!-- Subtitle -->
    <p class="text-xl md:text-2xl text-moss-700 max-w-3xl mx-auto mb-10 leading-relaxed">
      {subtitle}
    </p>
    
    {showCTA && (
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href="https://www.youtube.com/@front_yard_rebel"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-moss-600 hover:bg-moss-700 text-white px-8 py-4 rounded-full text-lg font-semibold transition-all shadow-lg hover:shadow-xl hover:-translate-y-1"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          Watch on YouTube
        </a>
        <a 
          href="https://www.instagram.com/front_yard_rebel"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-white hover:bg-moss-50 text-moss-700 px-8 py-4 rounded-full text-lg font-semibold transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 border border-moss-200"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          Follow on Instagram
        </a>
      </div>
    )}
    
    <!-- Scroll Indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-moss-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </div>
</section>
