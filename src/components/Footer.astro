---
const currentYear = new Date().getFullYear();
---

<footer class="bg-moss-900 text-moss-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <img 
            src="/logo.png" 
            alt="Front Yard Rebel" 
            class="w-12 h-12 rounded-full object-cover"
          />
          <div>
            <span class="text-xl font-bold text-white">Front Yard Rebel</span>
            <span class="block text-xs text-moss-300">From Grass to Garden</span>
          </div>
        </div>
        <p class="text-moss-300 max-w-md mb-6">
          Transforming Jacksonville front yards with beautiful Florida native plants. 
          Join the rebellion against boring lawns!
        </p>
        
        <!-- Social Links -->
        <div class="flex gap-4">
          <a 
            href="https://www.youtube.com/@front_yard_rebel" 
            target="_blank" 
            rel="noopener noreferrer"
            class="w-10 h-10 bg-moss-800 hover:bg-red-600 rounded-full flex items-center justify-center transition-colors"
            aria-label="YouTube"
          >
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
          <a 
            href="https://www.instagram.com/front_yard_rebel" 
            target="_blank" 
            rel="noopener noreferrer"
            class="w-10 h-10 bg-moss-800 hover:bg-pink-600 rounded-full flex items-center justify-center transition-colors"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li><a href="/" class="text-moss-300 hover:text-white transition-colors">Home</a></li>
          <li><a href="/about" class="text-moss-300 hover:text-white transition-colors">About</a></li>
          <li><a href="/gallery" class="text-moss-300 hover:text-white transition-colors">Gallery</a></li>
          <li><a href="/resources" class="text-moss-300 hover:text-white transition-colors">Resources</a></li>
          <li><a href="/contact" class="text-moss-300 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
      
      <!-- Contact Info -->
      <div>
        <h4 class="text-white font-semibold mb-4">Get In Touch</h4>
        <ul class="space-y-2 text-moss-300">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Jacksonville, FL
          </li>
          <li>
            <a href="/contact" class="hover:text-white transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Contact Us
            </a>
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Bottom Bar -->
    <div class="border-t border-moss-700 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-moss-400 text-sm">
        © {currentYear} Front Yard Rebel. All rights reserved.
      </p>
      <p class="text-moss-400 text-sm">
        🌱 Growing native in Jacksonville, FL
      </p>
    </div>
  </div>
</footer>
