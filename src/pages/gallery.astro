---
import Layout from '../layouts/Layout.astro';
import CallToAction from '../components/CallToAction.astro';
---

<Layout title="Gallery | Front Yard Rebel" description="See our Florida native plant garden transformation and get inspired for your own front yard.">
	<!-- Hero Section -->
	<section class="py-20 bg-gradient-to-br from-moss-100 to-earth-100">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h1 class="text-5xl md:text-6xl font-bold text-moss-900 mb-6">
				Garden Gallery
			</h1>
			<p class="text-xl text-moss-700">
				Our front yard transformation in progress
			</p>
		</div>
	</section>
	
	<!-- Gallery Note -->
	<section class="py-12 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<div class="bg-moss-50 border border-moss-200 rounded-2xl p-8">
				<span class="text-4xl mb-4 block">📸</span>
				<h2 class="text-2xl font-bold text-moss-800 mb-4">Photo Gallery Coming Soon!</h2>
				<p class="text-moss-600 mb-6">
					We're working on documenting our garden transformation. In the meantime, 
					check out our Instagram for the latest photos and updates!
				</p>
				<a 
					href="https://www.instagram.com/front_yard_rebel"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 bg-gradient-to-r from-purple-600 to-pink-600 text-white px-6 py-3 rounded-full font-semibold hover:opacity-90 transition-opacity"
				>
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
						<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
					</svg>
					View on Instagram
				</a>
			</div>
		</div>
	</section>
	
	<!-- Placeholder Gallery Grid -->
	<section class="py-12 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-bold text-moss-900 mb-8 text-center">Transformation Highlights</h2>
			
			<!-- Placeholder images - Replace with actual images -->
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{[
					{ title: "Before: Traditional Lawn", emoji: "🏡" },
					{ title: "Soil Preparation", emoji: "🪴" },
					{ title: "First Plantings", emoji: "🌱" },
					{ title: "Native Wildflowers", emoji: "🌸" },
					{ title: "Pollinator Activity", emoji: "🦋" },
					{ title: "Current Progress", emoji: "🌿" },
				].map((item) => (
					<div class="aspect-square bg-gradient-to-br from-moss-100 to-moss-200 rounded-2xl flex flex-col items-center justify-center p-6 border border-moss-200">
						<span class="text-6xl mb-4">{item.emoji}</span>
						<p class="text-moss-600 font-medium text-center">{item.title}</p>
						<p class="text-moss-400 text-sm mt-2">[Add your photo]</p>
					</div>
				))}
			</div>
			
			<p class="text-center text-moss-500 mt-8">
				<em>Add your own garden photos by replacing these placeholders in the code!</em>
			</p>
		</div>
	</section>
	
	<!-- Video Section -->
	<section class="py-20 bg-moss-50">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl font-bold text-moss-900 mb-6">Watch Our Videos</h2>
			<p class="text-xl text-moss-600 mb-8">
				Get the full story of our garden transformation on YouTube
			</p>
			
			<!-- Video Embed Placeholder -->
			<div class="bg-white rounded-2xl overflow-hidden shadow-lg">
				<div class="aspect-video bg-gradient-to-br from-gray-800 to-gray-900 flex items-center justify-center">
					<a 
						href="https://www.youtube.com/@front_yard_rebel"
						target="_blank"
						rel="noopener noreferrer"
						class="flex flex-col items-center gap-4 text-white hover:scale-105 transition-transform"
					>
						<div class="w-20 h-20 bg-red-600 rounded-full flex items-center justify-center">
							<svg class="w-10 h-10 ml-1" fill="currentColor" viewBox="0 0 24 24">
								<path d="M8 5v14l11-7z"/>
							</svg>
						</div>
						<span class="text-lg font-medium">Watch on YouTube</span>
					</a>
				</div>
				<div class="p-6">
					<p class="text-moss-600">
						Subscribe to our YouTube channel for garden tours, plant spotlights, 
						how-to guides, and our complete front yard transformation series!
					</p>
				</div>
			</div>
		</div>
	</section>
	
	<CallToAction />
</Layout>
