---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Front Yard Rebel" description="Get in touch with Front Yard Rebel. Connect with us on social media or send us a message.">
	<!-- Hero Section -->
	<section class="py-20 bg-gradient-to-br from-moss-100 to-earth-100">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h1 class="text-5xl md:text-6xl font-bold text-moss-900 mb-6">
				Get in Touch
			</h1>
			<p class="text-xl text-moss-700">
				We'd love to hear from you!
			</p>
		</div>
	</section>
	
	<!-- Contact Options -->
	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid md:grid-cols-2 gap-8 mb-16">
				<!-- Social Media -->
				<div class="bg-moss-50 rounded-2xl p-8 text-center">
					<div class="text-5xl mb-4">💬</div>
					<h2 class="text-2xl font-bold text-moss-800 mb-4">Connect on Social</h2>
					<p class="text-moss-600 mb-6">
						The best way to reach us is through our social media channels. 
						We're active on both YouTube and Instagram!
					</p>
					<div class="flex flex-col gap-4">
						<a 
							href="https://www.youtube.com/@front_yard_rebel"
							target="_blank"
							rel="noopener noreferrer"
							class="flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-full font-semibold transition-colors"
						>
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
								<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
							</svg>
							YouTube
						</a>
						<a 
							href="https://www.instagram.com/front_yard_rebel"
							target="_blank"
							rel="noopener noreferrer"
							class="flex items-center justify-center gap-2 bg-gradient-to-r from-purple-600 to-pink-600 hover:opacity-90 text-white px-6 py-3 rounded-full font-semibold transition-opacity"
						>
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
								<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
							</svg>
							Instagram
						</a>
					</div>
				</div>
				
				<!-- Location -->
				<div class="bg-moss-50 rounded-2xl p-8 text-center">
					<div class="text-5xl mb-4">📍</div>
					<h2 class="text-2xl font-bold text-moss-800 mb-4">Location</h2>
					<p class="text-moss-600 mb-6">
						We're based in beautiful Jacksonville, Florida – showcasing how native 
						plants can transform front yards in Northeast Florida's unique climate.
					</p>
					<div class="bg-white rounded-xl p-4 border border-moss-200">
						<p class="text-moss-700 font-medium">Jacksonville, FL</p>
						<p class="text-moss-500 text-sm">USDA Hardiness Zone 9a</p>
					</div>
				</div>
			</div>
			
			<!-- Contact Form -->
			<div class="bg-white rounded-2xl p-8 shadow-lg border border-moss-100">
				<h2 class="text-3xl font-bold text-moss-900 mb-6 text-center">Send a Message</h2>
				<p class="text-moss-600 text-center mb-8">
					Have a question, collaboration idea, or just want to say hi? Fill out the form below!
				</p>
				
				<!-- Note about form handling -->
				<div class="bg-earth-50 border border-earth-200 rounded-xl p-4 mb-8">
					<p class="text-earth-700 text-sm text-center">
						<strong>Note:</strong> This form is a template. To make it functional, you can integrate 
						it with a free service like <a href="https://formspree.io" target="_blank" class="underline">Formspree</a>, 
						<a href="https://getform.io" target="_blank" class="underline">Getform</a>, or 
						<a href="https://netlify.com/products/forms" target="_blank" class="underline">Netlify Forms</a>.
					</p>
				</div>
				
				<form class="space-y-6" action="#" method="POST">
					<div class="grid md:grid-cols-2 gap-6">
						<div>
							<label for="name" class="block text-sm font-medium text-moss-700 mb-2">
								Name
							</label>
							<input 
								type="text" 
								id="name" 
								name="name" 
								required
								class="w-full px-4 py-3 rounded-xl border border-moss-200 focus:border-moss-500 focus:ring-2 focus:ring-moss-200 outline-none transition-colors"
								placeholder="Your name"
							/>
						</div>
						<div>
							<label for="email" class="block text-sm font-medium text-moss-700 mb-2">
								Email
							</label>
							<input 
								type="email" 
								id="email" 
								name="email" 
								required
								class="w-full px-4 py-3 rounded-xl border border-moss-200 focus:border-moss-500 focus:ring-2 focus:ring-moss-200 outline-none transition-colors"
								placeholder="your@email.com"
							/>
						</div>
					</div>
					
					<div>
						<label for="subject" class="block text-sm font-medium text-moss-700 mb-2">
							Subject
						</label>
						<select 
							id="subject" 
							name="subject"
							class="w-full px-4 py-3 rounded-xl border border-moss-200 focus:border-moss-500 focus:ring-2 focus:ring-moss-200 outline-none transition-colors bg-white"
						>
							<option value="general">General Inquiry</option>
							<option value="collaboration">Collaboration</option>
							<option value="question">Gardening Question</option>
							<option value="feedback">Feedback</option>
							<option value="other">Other</option>
						</select>
					</div>
					
					<div>
						<label for="message" class="block text-sm font-medium text-moss-700 mb-2">
							Message
						</label>
						<textarea 
							id="message" 
							name="message" 
							rows="5" 
							required
							class="w-full px-4 py-3 rounded-xl border border-moss-200 focus:border-moss-500 focus:ring-2 focus:ring-moss-200 outline-none transition-colors resize-none"
							placeholder="Your message..."
						></textarea>
					</div>
					
					<div class="text-center">
						<button 
							type="submit"
							class="inline-flex items-center gap-2 bg-moss-600 hover:bg-moss-700 text-white px-8 py-4 rounded-full text-lg font-semibold transition-colors"
						>
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
							</svg>
							Send Message
						</button>
					</div>
				</form>
			</div>
		</div>
	</section>
	
	<!-- FAQ Section -->
	<section class="py-20 bg-moss-50">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-4xl font-bold text-moss-900 mb-12 text-center">Frequently Asked Questions</h2>
			
			<div class="space-y-6">
				<div class="bg-white rounded-2xl p-6 shadow-md">
					<h3 class="text-lg font-bold text-moss-800 mb-2">Do you offer landscaping services?</h3>
					<p class="text-moss-600">
						Currently, we're focused on documenting our own garden transformation and 
						educating others through our content. We don't offer professional landscaping 
						services at this time.
					</p>
				</div>
				
				<div class="bg-white rounded-2xl p-6 shadow-md">
					<h3 class="text-lg font-bold text-moss-800 mb-2">Where can I buy Florida native plants?</h3>
					<p class="text-moss-600">
						Check out local native plant nurseries in the Jacksonville area! We also 
						recommend attending Florida Native Plant Society sales. We share our 
						favorite sources on our YouTube channel.
					</p>
				</div>
				
				<div class="bg-white rounded-2xl p-6 shadow-md">
					<h3 class="text-lg font-bold text-moss-800 mb-2">Can I use your photos/videos?</h3>
					<p class="text-moss-600">
						Please reach out to us directly for any media usage requests. We're happy 
						to discuss collaborations and proper attribution.
					</p>
				</div>
				
				<div class="bg-white rounded-2xl p-6 shadow-md">
					<h3 class="text-lg font-bold text-moss-800 mb-2">Will you have merchandise available?</h3>
					<p class="text-moss-600">
						Yes! We're working on a merch line for fellow garden rebels. Follow us on 
						social media to be the first to know when it launches!
					</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
