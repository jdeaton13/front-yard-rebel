---
import Layout from '../layouts/Layout.astro';
import CallToAction from '../components/CallToAction.astro';
import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';
import { experimental_AstroContainer as AstroContainer } from 'astro/container';

const about = JSON.parse(
  readFileSync(join(process.cwd(), 'content/about/index.json'), 'utf-8')
);

// Render rich-text story as HTML paragraphs
function renderStory(content: any): string {
  if (!content?.children) return '';
  return content.children
    .map((block: any) => {
      const text = block.children?.map((n: any) => n.text).join('') ?? '';
      return `<p class="text-moss-600 mb-6 leading-relaxed">${text}</p>`;
    })
    .join('');
}
---

<Layout title="About | Front Yard Rebel" description="Learn about Front Yard Rebel and our mission to transform Jacksonville front yards with beautiful Florida native plants.">
	<!-- Hero Section -->
	<section class="py-20 bg-gradient-to-br from-moss-100 to-earth-100">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h1 class="text-5xl md:text-6xl font-bold text-moss-900 mb-6">
				{about.pageTitle}
			</h1>
			<p class="text-xl text-moss-700">
				{about.pageSubtitle}
			</p>
		</div>
	</section>
	
	<!-- Story Section -->
	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-bold text-moss-900 mb-6">{about.storyTitle}</h2>
			<div set:html={renderStory(about.storyContent)} />

			<!-- Profile Image -->
			<div class="my-12 text-center">
				{about.profileImage ? (
					<img
						src={about.profileImage}
						alt={about.profileCaption}
						class="w-48 h-48 mx-auto rounded-full object-cover shadow-lg"
					/>
				) : (
					<div class="inline-flex w-48 h-48 bg-gradient-to-br from-moss-200 to-moss-300 rounded-full items-center justify-center">
						<span class="text-6xl">👤</span>
					</div>
				)}
				<p class="mt-4 text-moss-500 italic">{about.profileCaption}</p>
			</div>

			<h2 class="text-3xl font-bold text-moss-900 mb-6 mt-12">Our Mission</h2>
			<p class="text-moss-600 mb-6 leading-relaxed">{about.missionIntro}</p>
			<ul class="space-y-4 mb-8">
				{about.missionPoints?.map((point: any) => (
					<li class="flex items-start gap-3">
						<span class="text-moss-500 text-xl">{point.emoji}</span>
						<span class="text-moss-600">{point.text}</span>
					</li>
				))}
			</ul>

			<h2 class="text-3xl font-bold text-moss-900 mb-6 mt-12">Why "Rebel"?</h2>
			{about.rebelSectionContent?.split('\n\n').map((para: string) => (
				<p class="text-moss-600 mb-6 leading-relaxed">{para}</p>
			))}
		</div>
	</section>
	
	<!-- Values Section -->
	<section class="py-20 bg-moss-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-4xl font-bold text-moss-900 text-center mb-12">Our Values</h2>
			
			<div class="grid md:grid-cols-3 gap-8">
				<div class="bg-white p-8 rounded-2xl shadow-md text-center">
					<div class="text-5xl mb-4">🌿</div>
					<h3 class="text-xl font-bold text-moss-800 mb-3">Sustainability</h3>
					<p class="text-moss-600">
						Every decision we make considers the long-term impact on our environment and ecosystem.
					</p>
				</div>
				
				<div class="bg-white p-8 rounded-2xl shadow-md text-center">
					<div class="text-5xl mb-4">📖</div>
					<h3 class="text-xl font-bold text-moss-800 mb-3">Education</h3>
					<p class="text-moss-600">
						We share everything we learn, making native gardening accessible to everyone.
					</p>
				</div>
				
				<div class="bg-white p-8 rounded-2xl shadow-md text-center">
					<div class="text-5xl mb-4">🤝</div>
					<h3 class="text-xl font-bold text-moss-800 mb-3">Community</h3>
					<p class="text-moss-600">
						We're building a community of garden rebels who support and inspire each other.
					</p>
				</div>
			</div>
		</div>
	</section>
	
	<CallToAction 
		title="Join Our Community"
		description="Follow along on YouTube and Instagram to be part of the native plant movement in Jacksonville!"
	/>
</Layout>
