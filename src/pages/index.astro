---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import CallToAction from '../components/CallToAction.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

const home = JSON.parse(
  readFileSync(join(process.cwd(), 'content/home/index.json'), 'utf-8')
);
---

<Layout>
	<Hero title={home.heroTitle} subtitle={home.heroSubtitle} />
	
	<!-- Mission Statement -->
	<section class="py-20 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl md:text-4xl font-bold text-moss-900 mb-6">
				What is Front Yard Rebel?
			</h2>
			<p class={`text-lg text-moss-600 leading-relaxed ${home.badges?.length > 0 ? 'mb-8' : ''}`}>
				{home.missionStatement}
			</p>
			{home.badges?.length > 0 && (
				<div class="flex flex-wrap justify-center gap-6 text-moss-700">
					{home.badges.map((badge: any) => (
						<div class="flex items-center gap-2">
							<span class="text-2xl">{badge.emoji}</span>
							<span>{badge.text}</span>
						</div>
					))}
				</div>
			)}
		</div>
	</section>
	
	<Features />
	
	<!-- Featured Content Section -->
	<section class="py-20 bg-earth-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-4xl font-bold text-moss-900 mb-4">
					Follow Our Journey
				</h2>
				<p class="text-xl text-moss-600">
					Watch our latest videos and stay updated on our native garden transformation
				</p>
			</div>
			
			<div class="grid md:grid-cols-2 gap-8">
				<!-- YouTube Embed Placeholder -->
				<div class="bg-white rounded-2xl p-8 shadow-md">
					<div class="flex items-center gap-3 mb-4">
						<svg class="w-8 h-8 text-red-600" fill="currentColor" viewBox="0 0 24 24">
							<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
						</svg>
						<h3 class="text-2xl font-bold text-moss-800">YouTube Channel</h3>
					</div>
					<p class="text-moss-600 mb-6">
						In-depth tutorials, garden tours, plant spotlights, and our ongoing front yard transformation journey.
					</p>
					<a 
						href="https://www.youtube.com/@front_yard_rebel"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 text-red-600 font-semibold hover:text-red-700"
					>
						Visit Channel
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
						</svg>
					</a>
				</div>
				
				<!-- Instagram Embed Placeholder -->
				<div class="bg-white rounded-2xl p-8 shadow-md">
					<div class="flex items-center gap-3 mb-4">
						<svg class="w-8 h-8 text-pink-600" fill="currentColor" viewBox="0 0 24 24">
							<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
						</svg>
						<h3 class="text-2xl font-bold text-moss-800">Instagram</h3>
					</div>
					<p class="text-moss-600 mb-6">
						Daily updates, beautiful plant photos, behind-the-scenes content, and quick gardening tips.
					</p>
					<a 
						href="https://www.instagram.com/front_yard_rebel"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 text-pink-600 font-semibold hover:text-pink-700"
					>
						Follow Us
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
						</svg>
					</a>
				</div>
			</div>
		</div>
	</section>
	
	<CallToAction />
</Layout>
